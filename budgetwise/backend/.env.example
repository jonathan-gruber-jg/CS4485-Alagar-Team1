DATABASE_URL="postgresql://myapp:secret@localhost/myapp_db"
JWT_SECRET="budgetwise_dev_secret_9f3a2c1d7e6b5a4c8d1f0e9b2a7c6d5e"

PORT=5001
CORS_ORIGIN="http://localhost:3000"

# Hostname of front-end server.
#
# Default: os.hostname().
FRONTEND_SERVER_NAME=HOSTNAME

# Mail server configuration.
#
# These variables govern how
# the back end connects with and uses the SMTP/mail server.
# The defaults should probably suffice,
# depending upon the configuration of the mail server,
# of course.
#
# The mail server is currently only used
# for sending reset-password email messages.

# The URL to be used for connecting to the mail server.
# See the discussion on connection URLs
# at https://nodemailer.com/smtp#creating-a-transport
# for details.
#
# Default: smtp://localhost/?ignoreTLS=true.
MAIL_SERVER_URL=smtp://localhost/?ignoreTLS=true
# The email domain corresponding to the mail server.
#
# Default os.hostname().
MAIL_SERVER_DOMAIN=DOMAIN
# The local part of the "no reply" mailbox on the mail server.
# ("Local part" is the term for the part before "@" in an email address.)
#
# Default: no-reply.
MAIL_SERVER_MBOX_NO_REPLY_LOCAL_PART=no-reply
# The display name of the "no reply" mailbox on the mail server.
# (The human-readable name for an email account in an email message.)
#
# Default: Budgetwise
MAIL_SERVER_MBOX_NO_REPLY_DISPLAY_NAME=Budgetwise

# Optional for AI features
GROQ_API_KEY="GROQ_KEY_PLACEHOLDER"
GROQ_MODEL_PRIMARY="llama-3.3-70b-versatile"
GROQ_MODEL_FALLBACK_1="openai/gpt-oss-20b"
GROQ_MODEL_FALLBACK_2="openai/gpt-oss-120b"
GROQ_MAX_TOKENS_INSIGHTS=320
GROQ_MAX_TOKENS_COMPARISON=480
GROQ_MAX_INPUT_CATEGORIES=8
