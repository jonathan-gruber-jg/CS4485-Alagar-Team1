DATABASE_URL="postgresql://myapp:secret@localhost:5433/myapp_db"
JWT_SECRET="budgetwise_dev_secret_9f3a2c1d7e6b5a4c8d1f0e9b2a7c6d5e"

PORT=5001
CORS_ORIGIN="http://localhost:3000"

# Default: os.hostname().
FRONTEND_HOSTNAME=HOSTNAME

# Mail server configuration.
#
# See mail-config-howto.md for a walkthrough
# upon setting up a working configuration with these variables.
#
# These variables govern how
# the back end connects with and uses the SMTP/mail server.
# The mail server is currently only used
# for sending reset-password email messages.
#
# Example configuration:
#
# # This is the hostname of Gmail's SMTP server.
# MAIL_SERVER_NAME=smtp.gmail.com
# # We must connect to the mail server via this port
# # if we are to communicate with it directly over TLS.
# MAIL_SERVER_PORT=465
# # Communicate with the mail server directly over TLS.
# MAIL_SERVER_SECURE=1
# A throw-away Google account for testing.
# MAIL_SERVER_USER="throwaway@gmail.com",
# # An app password is distinct
# # from the regular password of a Google account.
# # See https://support.google.com/accounts/answer/185833 for full details.
# MAIL_SERVER_PASSWORD"App password"

# The host name of the mail server.
# You will have to look this up for whatever mail server you use.
#
# Default: localhost.
MAIL_SERVER_NAME=MAIL_SERVER_NAME_PLACEHOLDER
# The port upon which the mail server listens for mail from mail user agents.
# You will have to look this up for whatever mail server you use.
# This is usually 25, 465, or 587.
#
# Default: 465.
MAIL_SERVER_PORT=MAIL_SERVER_PORT_PLACEHOLDER
# Whether the connection with the mail server is initially over TLS.
# An nonempty string indicates true;
# an empty string indicates false.
# Even if the connection is not initially over TLS,
# the mail user agent and the mail server
# may choose to upgrade the connection to TLS
# before any email messages are transferred
# (the details are beyond the scope of this file).
#
# Default: true.
MAIL_SERVER_SECURE=MAIL_SERVER_SECURE_PLACEHOLDER
# The username to use for authenticating to the mail server.
#
# Default: undefined.
MAIL_SERVER_USER=MAIL_SERVER_USER_PLACEHOLDER
# The password to use for authenticating to the mail server.
#
# Default: undefined.
MAIL_SERVER_PASSWORD=MAIL_SERVER_PASSWORD_PLACEHOLDER

# The display name of the sender of reset-password emails.
#
# Default: Budgetwise.
RESET_PASSWORD_SENDER_NAME=RESET_PASSWORD_SENDER_NAME_PLACEHOLDER
# The email address of the sender of reset-password emails.
#
# Default: no-reply@localhost
RESET_PASSWORD_SENDER_ADDRESS=RESET_PASSWORD_SENDER_ADDRESS_PLACEHOLDER

# Optional for AI features
GROQ_API_KEY="GROQ_KEY_PLACEHOLDER"
GROQ_MODEL_PRIMARY="llama-3.3-70b-versatile"
GROQ_MODEL_FALLBACK_1="openai/gpt-oss-20b"
GROQ_MODEL_FALLBACK_2="openai/gpt-oss-120b"
GROQ_MAX_TOKENS_INSIGHTS=320
GROQ_MAX_TOKENS_COMPARISON=480
GROQ_MAX_INPUT_CATEGORIES=8
