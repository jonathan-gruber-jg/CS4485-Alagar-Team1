# Environment variables for the BudgetWise frontend
#
# Copy this file to `.env.local` when running the project locally
# Do not commit `.env.local` to the repository
#
# These values are used by the frontend to connect to the backend API

NEXT_PUBLIC_API_BASE_URL="http://localhost:5001"
NEXT_PUBLIC_PLAID_DEMO_DIRECT_IMPORT_ENABLED="false"
